# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
EMAIL_FROM=Renewal Radar <notifications@renewalradar.com>

# ─── Database (Neon) ──────────────────────────────────────────────────────
# Get from https://neon.tech → your project → Connection Details (use Pooled connection)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Authentication (Clerk) ───────────────────────────────────────────────
# Get from https://clerk.com → your application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook — created in Clerk dashboard → Webhooks → Add Endpoint
# Point to https://<your-domain>/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# ─── Billing (Stripe) ─────────────────────────────────────────────────────
# Get from https://stripe.com → Developers → API Keys (Test mode first)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx

# Create products/prices in Stripe; use the annual price IDs here
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_GROWTH_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook — for local dev use: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# For production: Stripe dashboard → Webhooks → Add Endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# ─── Email (Resend) ───────────────────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# ─── Scheduled jobs (Inngest) ─────────────────────────────────────────────
# Get from https://inngest.com → your app → Settings
INNGEST_EVENT_KEY=xxxxxxxxxxxxxxxxxxxxxx
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxxxxxxxx

# ─── Error tracking (Sentry) ──────────────────────────────────────────────
# Optional in dev; set in production. SENTRY_DSN is read by the public
# (browser) bundle as NEXT_PUBLIC_SENTRY_DSN if you want client errors
# to surface — set both to the same value.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Integration secret encryption ────────────────────────────────────────
# 32-byte symmetric master key used to envelope-encrypt customer-provided
# integration secrets (Slack webhook URLs, ICS export tokens) before they
# land in the database. REQUIRED in production — the encryption module
# throws at boot if missing when NODE_ENV=production.
#
# Generate one with: openssl rand -base64 32
INTEGRATIONS_ENCRYPTION_KEY=

# ─── Demo mode (local + staging review only) ──────────────────────────────
# Double-guarded: ignored if NODE_ENV=production. See
# docs/architecture/adr/0004-demo-mode.md for the rationale.
DEMO_MODE=false

# ─── Phase C: Documents + AI extraction providers ─────────────────────────
# Pluggable provider stack. Defaults work today against the heuristic stub
# + local filesystem; flip to the real providers when you provision keys.
#
# STORAGE_PROVIDER:
#   local-filesystem (default) — dev + tests; bytes land under ./.storage/
#   r2                          — production; requires R2 credentials below
STORAGE_PROVIDER=local-filesystem
# STORAGE_LOCAL_ROOT=/path/to/storage  # optional; defaults to ./.storage
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
#
# AI_EXTRACTION_PROVIDER:
#   heuristic-stub (default) — deterministic regex extraction; no API cost
#   anthropic                — Claude Sonnet 4.6; requires ANTHROPIC_API_KEY
AI_EXTRACTION_PROVIDER=heuristic-stub
# ANTHROPIC_API_KEY=
#
# OCR_PROVIDER:
#   pdf-parse-only (default) — searchable PDFs only; free, in-process
#   mistral                  — image-OCR fallback; requires MISTRAL_API_KEY
OCR_PROVIDER=pdf-parse-only
# MISTRAL_API_KEY=
#
# ─── CRM (marketing leads) ────────────────────────────────────────────────
# CRM_PROVIDER — where captured marketing leads get pushed.
#   console       (default) — prints to stdout; safe for dev / CI
#   google-sheets           — appends to a Google Sheet (start here)
#   hubspot                 — HubSpot scaffold (replace stub with real impl)
#
# Leads are ALWAYS written to the `lead` table first; the CRM push is a
# fire-and-forget side effect, so CRM downtime never costs a lead.
#
# CRM_PROVIDER=google-sheets
#
# Google Sheets setup (required when CRM_PROVIDER=google-sheets):
#   1. Create a Google Cloud service account with the
#      https://www.googleapis.com/auth/spreadsheets scope.
#   2. Share the target spreadsheet with the service-account email
#      (give it Editor access).
#   3. Fill in the three vars below.
#
# The spreadsheet should have a "Leads" worksheet with this header row
# (13 columns, in order):
#   Lead ID | Created at | Email | Full name | Company | Job title |
#   Source  | Intent     | Message | Consent marketing | UTM      |
#   Page URL | Referrer
#
# GOOGLE_SERVICE_ACCOUNT_EMAIL=leads-writer@my-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_RANGE=Leads!A:M
#
# HubSpot (later) — replace HubspotNotConfiguredProvider with a real
# implementation before flipping CRM_PROVIDER=hubspot.
# HUBSPOT_PRIVATE_APP_TOKEN=
