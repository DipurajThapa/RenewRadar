# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
EMAIL_FROM=Renewal Radar <notifications@renewalradar.com>

# ─── Database (Neon) ──────────────────────────────────────────────────────
# Get from https://neon.tech → your project → Connection Details (use Pooled connection)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Authentication (Clerk) ───────────────────────────────────────────────
# Get from https://clerk.com → your application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook — created in Clerk dashboard → Webhooks → Add Endpoint
# Point to https://<your-domain>/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# ─── Billing (Stripe) ─────────────────────────────────────────────────────
# Get from https://stripe.com → Developers → API Keys (Test mode first)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx

# Create products/prices in Stripe; use the annual price IDs here
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_GROWTH_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook — for local dev use: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# For production: Stripe dashboard → Webhooks → Add Endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# ─── Email (Resend) ───────────────────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# ─── Scheduled jobs (Inngest) ─────────────────────────────────────────────
# Get from https://inngest.com → your app → Settings
INNGEST_EVENT_KEY=xxxxxxxxxxxxxxxxxxxxxx
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxxxxxxxx

# ─── Error tracking (Sentry) ──────────────────────────────────────────────
# Optional in dev; set in production
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
