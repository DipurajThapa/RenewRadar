# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ─── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
EMAIL_FROM=Renewal Radar <notifications@renewalradar.com>

# ─── Database (Neon) ──────────────────────────────────────────────────────
# Get from https://neon.tech → your project → Connection Details (use Pooled connection)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Authentication (Clerk) ───────────────────────────────────────────────
# Get from https://clerk.com → your application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk webhook — created in Clerk dashboard → Webhooks → Add Endpoint
# Point to https://<your-domain>/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
# Must be a valid base64 secret (the part after `whsec_`); svix throws on a
# malformed value. Copy the real value from the Clerk dashboard.
CLERK_WEBHOOK_SECRET=whsec_ZGVtb19jbGVya193ZWJob29rX3NlY3JldF9rZXk=

# ─── Billing (Stripe) ─────────────────────────────────────────────────────
# Get from https://stripe.com → Developers → API Keys (Test mode first)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx

# Create products/prices in Stripe; use the annual price IDs here
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_GROWTH_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxx

# Stripe webhook — for local dev use: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# For production: Stripe dashboard → Webhooks → Add Endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# ─── Email (Resend) ───────────────────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# ─── Scheduled jobs (Inngest) ─────────────────────────────────────────────
# Get from https://inngest.com → your app → Settings
INNGEST_EVENT_KEY=xxxxxxxxxxxxxxxxxxxxxx
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxxxxxxxx

# ─── Error tracking (Sentry) ──────────────────────────────────────────────
# Optional in dev; set in production. SENTRY_DSN is read by the public
# (browser) bundle as NEXT_PUBLIC_SENTRY_DSN if you want client errors
# to surface — set both to the same value.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Integration secret encryption ────────────────────────────────────────
# 32-byte symmetric master key used to envelope-encrypt customer-provided
# integration secrets (Slack webhook URLs, ICS export tokens) before they
# land in the database. REQUIRED in production — the encryption module
# throws at boot if missing when NODE_ENV=production.
#
# Generate one with: openssl rand -base64 32
INTEGRATIONS_ENCRYPTION_KEY=

# ─── Demo mode (local + staging review only) ──────────────────────────────
# Double-guarded: ignored if NODE_ENV=production. See
# docs/architecture/adr/0004-demo-mode.md for the rationale.
DEMO_MODE=false

# ─── Phase C: Documents + AI extraction providers ─────────────────────────
# Pluggable provider stack. Defaults work today against the heuristic stub
# + local filesystem; flip to the real providers when you provision keys.
#
# STORAGE_PROVIDER:
#   local-filesystem (default) — dev + tests; bytes land under ./.storage/
#   r2                          — production; requires R2 credentials below
STORAGE_PROVIDER=local-filesystem
# STORAGE_LOCAL_ROOT=/path/to/storage  # optional; defaults to ./.storage
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
#
# This product is AI-FIRST: both providers DEFAULT to the local LLM (ollama).
# Each self-falls-back to its deterministic engine per-call when no model server
# is reachable, so a model-less environment still works. In production, either run
# a model (point LOCAL_LLM_BASE_URL at it) or set these to the deterministic
# engines below. Tests pin deterministic via .env.test.
#
# AI_EXTRACTION_PROVIDER:
#   ollama | local (default) — local LLM (qwen3.6); reads contracts and must quote
#                              evidence verbatim or the field is dropped.
#   heuristic-stub           — deterministic regex extraction; no model needed
#   anthropic                — Claude Sonnet 4.6; requires ANTHROPIC_API_KEY
AI_EXTRACTION_PROVIDER=ollama
# ANTHROPIC_API_KEY=
#
# AI_REASONING_PROVIDER — engine for the Renewal Intelligence Brief + Ask:
#   ollama | local (default) — local LLM (qwen3.6) via Ollama; no API key. Powers
#                              semantic intent routing + grounded answers. Self-
#                              falls-back to deterministic on any failure.
#   deterministic            — offline rules/regression engine; no model needed
#   anthropic                — hosted Claude; requires ANTHROPIC_API_KEY
AI_REASONING_PROVIDER=ollama
#
# ─── Local LLM (Ollama) — only read when AI_*_PROVIDER=ollama|local ──────────
# Run a model first:  ollama pull qwen3.6:latest   (then `ollama serve`)
# LOCAL_LLM_BASE_URL=http://localhost:11434   # Ollama server, no trailing slash
# LOCAL_LLM_MODEL=qwen3.6:latest              # any installed Ollama tag
# LOCAL_LLM_TIMEOUT_MS=120000                 # cold model load can be slow
# LOCAL_LLM_TEMPERATURE=0                     # 0 = best for structured JSON
# LOCAL_LLM_NUM_CTX=8192                      # context window (tokens)
# LOCAL_LLM_THINK=false                       # true = richer reasoning, slower
#
# Production serving — point at any OpenAI-compatible endpoint (vLLM / TGI /
# Ollama's own /v1 / a hosted gateway). A pure CONFIG SWAP — no code change:
# LLM_API_STYLE=openai                        # use /v1/chat/completions
# LLM_API_KEY=                                # Bearer token for a hosted endpoint
#   (then set LOCAL_LLM_BASE_URL to the served URL + LOCAL_LLM_MODEL to its name)
# LLM_CACHE_ENABLED=true                       # cache identical model calls (TTL+LRU)
#   The client also has a circuit breaker: after repeated failures it fast-fails
#   so the deterministic fallback fires immediately instead of waiting out timeouts.
# LLM_MAX_CONCURRENCY=0                         # bounded-concurrency queue (B4); 0 = unlimited
#   On a SINGLE GPU, concurrent generations share compute (a burst of 4 turned a
#   16s brief into 50–65s — measured). Set this to your replica/GPU count so calls
#   QUEUE at full speed instead of contending. A served multi-replica deployment
#   raises it; a single local GPU is best at 1–2.
#
# Unit economics (Phase 6) — token accounting + cost model. Local inference is
# free; these price a HOSTED-equivalent so cost is a measured number, not a guess.
# Every LLM call meters real prompt + completion tokens (Ollama prompt_eval_count
# + eval_count / OpenAI usage.*) into a process meter. `pnpm ai:cost` reports
# $/op + a monthly projection + cache savings; `pnpm ai:leaderboard` adds a $/doc
# column so you pick the right model tier by accuracy × latency × cost.
# LLM_PRICE_INPUT_PER_1K=0.00015              # $/1k prompt tokens (0 = free/local)
# LLM_PRICE_OUTPUT_PER_1K=0.0002              # $/1k completion tokens (0 = free/local)
#   The cost SCRIPTS use COST_INPUT_PER_1K / COST_OUTPUT_PER_1K for their illustrative
#   hosted-equivalent rate (defaults above), independent of the runtime meter.
#   A per-account monthly spend cap is enforced in app code via checkBudget() —
#   over budget, the deterministic engine serves for free (never overbill).
#
# Semantic retrieval (Phase A) — the grounded "Ask" assistant ranks the account's
# real facts by embedding similarity, so off-menu / paraphrased questions surface
# the right facts (which the fixed-enum keyword router cannot). Facts still come
# from SQL — embeddings only RE-RANK, never invent.
# AI_SEMANTIC_RETRIEVAL=on                     # default on; "off" → keyword dispatch only
# AI_EMBEDDINGS_PROVIDER=lexical               # default: deterministic, model-free vectors
#   AI_EMBEDDINGS_PROVIDER=ollama              # NEURAL embeddings (handles pure synonyms,
#                                              #   e.g. "worried"→risk, that lexical can't)
#   LOCAL_EMBED_MODEL=all-minilm               #   (then: ollama pull all-minilm)
#   NB: use all-minilm, NOT nomic-embed-text — measured, nomic does NOT separate
#   relevant from irrelevant on our short fact strings (weather ≈ on-topic); all-minilm
#   gives a clean gap. Ollama embeddings self-fall-back to lexical if unavailable.
#
# AI_AUTO_APPLY_ENABLED — confidence-gated auto-apply of extracted fields.
#   Default OFF (advisor-not-agent). When "true", after extraction the system
#   auto-applies ONLY safe, high-confidence (>=90%) fields (renewal/expiry date,
#   notice period, auto-renew) to the account's own records — fully audited and
#   one-click reversible. Everything else still goes to the human review queue.
# AI_AUTO_APPLY_ENABLED=false
#
# OCR_PROVIDER:
#   pdf-parse-only (default) — searchable PDFs only; free, in-process
#   mistral                  — image-OCR fallback; requires MISTRAL_API_KEY
OCR_PROVIDER=pdf-parse-only
# MISTRAL_API_KEY=
#
# ─── CRM (marketing leads) ────────────────────────────────────────────────
# CRM_PROVIDER — where captured marketing leads get pushed.
#   console       (default) — prints to stdout; safe for dev / CI
#   google-sheets           — appends to a Google Sheet (start here)
#   hubspot                 — HubSpot scaffold (replace stub with real impl)
#
# Leads are ALWAYS written to the `lead` table first; the CRM push is a
# fire-and-forget side effect, so CRM downtime never costs a lead.
#
# CRM_PROVIDER=google-sheets
#
# Google Sheets setup (required when CRM_PROVIDER=google-sheets):
#   1. Create a Google Cloud service account with the
#      https://www.googleapis.com/auth/spreadsheets scope.
#   2. Share the target spreadsheet with the service-account email
#      (give it Editor access).
#   3. Fill in the three vars below.
#
# The spreadsheet should have a "Leads" worksheet with this header row
# (13 columns, in order):
#   Lead ID | Created at | Email | Full name | Company | Job title |
#   Source  | Intent     | Message | Consent marketing | UTM      |
#   Page URL | Referrer
#
# GOOGLE_SERVICE_ACCOUNT_EMAIL=leads-writer@my-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_RANGE=Leads!A:M
#
# HubSpot (later) — replace HubspotNotConfiguredProvider with a real
# implementation before flipping CRM_PROVIDER=hubspot.
# HUBSPOT_PRIVATE_APP_TOKEN=
