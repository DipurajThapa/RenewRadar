{
  "name": "renewal-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm db:migrate",
    "dev": "next dev",
    "prebuild": "echo 'Skipping migrations at build time; run pnpm db:migrate against the prod DB in your deploy pipeline before traffic shifts.'",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "prestart": "pnpm db:migrate",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "lint": "eslint src",
    "lint:strict": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:test:migrate": "dotenv -e .env.test -- drizzle-kit migrate",
    "ai:benchmark": "dotenv -e .env.local -- tsx scripts/ai-eval/benchmark.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "email:dev": "email dev --dir src/emails --port 3001"
  },
  "dependencies": {
    "@clerk/nextjs": "^5.7.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-email/components": "^0.0.25",
    "@react-email/render": "^1.0.1",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^8.30.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.34.0",
    "gray-matter": "^4.0.3",
    "inngest": "^3.22.0",
    "lucide-react": "^0.445.0",
    "mammoth": "^1.12.0",
    "next": "^14.2.13",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^3.0.1",
    "react-hook-form": "^7.76.1",
    "reading-time": "^1.5.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "svix": "^1.36.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.5.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.0",
    "@types/xlsx": "^0.0.36",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.25.0",
    "eslint": "^9.10.0",
    "eslint-config-next": "^14.2.13",
    "globals": "^17.6.0",
    "jszip": "^3.10.1",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.10.0"
}
