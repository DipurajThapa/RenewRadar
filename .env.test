# Test-only environment. Loaded by vitest.config.ts.
# This DB is truncated between tests — do not point at anything precious.
DATABASE_URL_TEST=postgresql://dipurajthapa@localhost:5432/renewal_radar_test
# Also expose under the canonical name so drizzle-kit picks it up when run via
# `pnpm db:test:migrate` (which loads this file).
DATABASE_URL=postgresql://dipurajthapa@localhost:5432/renewal_radar_test
# Demo mode has no effect inside tests (we exercise real auth-resolved IDs),
# but we set it false to avoid any code path that branches on it accidentally.
DEMO_MODE=false
NODE_ENV=test
